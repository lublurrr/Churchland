<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Python on GH Pages</title>
    <link rel="stylesheet" href="https://pyscript.net/releases/2024.1.1/core.css" />
    <script type="module" src="https://pyscript.net/releases/2024.1.1/core.js"></script>
</head>
<body>

    <h1>Type some Python code or see the output below:</h1>
    
    <script type="py" async>
from pyscript import input

print(r'''
                                             +
                                             A
                                          __/_\__
                                         /\-'o'-/\
                                        _||:<_>:||_
                                       /\_/=====\_/\
                                      _|:_:_[I]_:_:|_
                                    _/::::::::::::::::\_
                                  _/::::::::::::::::::::\_
                                 /::::::::::::::::::::::::\
''')
print("Welcome to Churchland.")
print("Your mission is to find a way to destroy the dragon!\n")

# Using 'await' tells the browser to pause and wait for the user to type
direction = (await input("Press type left or right to proceed: ")).lower()

if direction == "left":
    print("You are about to enter the church!\n")
    door = (await input("What door are you going through? Type backdoor or entrance door: ")).lower()
    
    if door == "entrance" or door == "entrance door":
        print("You entered the church successfully! Now then...\n")
        print("As a warrior, you have a myriad of weapons. Which one are you using?\n")
        print("- Axe\n- Lightsaber\n- Chainsaw\n- Traditional sword")
        weapon = (await input("Type wisely: ")).lower()
        
        if weapon == "axe":
            print("You were burned by a spitball from the dragon! Game Over!")
        elif weapon == "lightsaber":
            print("You win the fight as a Jedi warrior! Congratulations!")
        elif weapon == "sword" or weapon == "traditional sword":
            print("You accidentally kill the held captive princess! Game Over!")
        elif weapon == "chainsaw":
            print("You were beaten to death by the dragon. Game Over!")
        else:
            print("You didn't choose any right weapon so you lose instantly the fight. Game Over!")
    else:
        print("You were eaten by the dragon! Game Over!")
else:
    print("You fall into a hole. Game Over!")
    </script>

</body>
</html>
